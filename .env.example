# Credenciales de Supabase.
# Obtenlas en el dashboard del proyecto: Settings → API Keys.

# URL pública del proyecto. Ej: https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Secret key (antes "service_role"). SOLO para scripts de servidor/seed.
# NUNCA la embebas en el cliente ni la comitees al repo.
SUPABASE_SERVICE_ROLE_KEY=

# Publishable key (antes "anon"). Segura de exponer al cliente (sujeta a RLS).
SUPABASE_ANON_KEY=

# --- Edge Function `llm` ---
# Estos NO van en el .env del cliente; se configuran como secrets en Supabase
# (dashboard → Edge Functions → Secrets, o `supabase secrets set ...`).
# Aquí sólo se listan para referencia del equipo.

# GEMINI_API_KEY         obligatoria — https://aistudio.google.com/apikey
# GEMINI_MODEL           opcional, default "gemini-2.5-flash-lite"
# LLM_TIMEOUT_MS         opcional, default 7000
