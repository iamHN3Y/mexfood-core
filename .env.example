# Credenciales de Supabase.
# Obtenlas en el dashboard del proyecto: Settings → API Keys.

# URL pública del proyecto. Ej: https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Secret key (antes "service_role"). SOLO para scripts de servidor/seed.
# NUNCA la embebas en el cliente ni la comitees al repo.
SUPABASE_SERVICE_ROLE_KEY=

# Publishable key (antes "anon"). Segura de exponer al cliente (sujeta a RLS).
SUPABASE_ANON_KEY=
